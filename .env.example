# ═══════════════════════════════════════════════════════════════════════════
# Zephr Chat - Environment Variables (Razorpay Integration)
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git! Add it to .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ── TELEGRAM BOT ───────────────────────────────────────────────────────────
# Get from: @BotFather in Telegram
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Your web app URL (where frontend is hosted)
WEBAPP_URL=https://yourdomain.com

# For webhooks (optional, leave empty for polling)
WEBHOOK_URL=
WEBHOOK_PATH=/webhook

# ── RAZORPAY PAYMENT CONFIGURATION ─────────────────────────────────────────
# 
# SETUP STEPS:
# 1. Create account at https://razorpay.com
# 2. Complete KYC verification
# 3. Go to Dashboard → Settings → API Keys
# 4. Generate keys (Test Mode first, then Live Mode when ready)
#
# TEST MODE (for development and testing):
RAZORPAY_KEY_ID=rzp_test_SfNMBB4UtGehsK
RAZORPAY_KEY_SECRET=gOBB6Ppe8TzMM1YeOfyHFuXw
RAZORPAY_MODE=test

# LIVE MODE (for production - uncomment when ready to go live):
# RAZORPAY_KEY_ID=rzp_live_AbCdEfGhIjKlMnOp
# RAZORPAY_KEY_SECRET=YourLiveSecretKeyHere123456789
# RAZORPAY_MODE=live

# WEBHOOK SECRET (for automatic payment confirmation):
# Get from: Razorpay Dashboard → Settings → Webhooks
# Create webhook: https://your-domain.com/api/razorpay-webhook
# Copy the "Webhook Secret" provided
RAZORPAY_WEBHOOK_SECRET=YourWebhookSecretHere

# ── DATABASE ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zephr:zephr@localhost:5432/zephrdb

# ── REDIS ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── SECURITY ───────────────────────────────────────────────────────────────
# Generate a random 64-character string
# You can use: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-64-character-string-openssl-rand-hex-32

# ── AI MODERATION (Optional) ───────────────────────────────────────────────
# Google Perspective API for content moderation
# Get from: https://perspectiveapi.com/
PERSPECTIVE_API_KEY=
TOXICITY_THRESHOLD=0.75

# ── SESSION & RATE LIMITING ────────────────────────────────────────────────
SESSION_TTL=3600           # 1 hour
QUEUE_TTL=300              # 5 minutes
MAX_MSG_LENGTH=2000

# ── VIP PRICING ────────────────────────────────────────────────────────────
# Prices in smallest currency unit (paise for INR, cents for USD)
# These are reference values - actual prices in code

# India (INR)
VIP_MONTHLY_PRICE_INR=41500      # ₹415
VIP_QUARTERLY_PRICE_INR=83000    # ₹830

# International (USD)
VIP_MONTHLY_PRICE_USD=499        # $4.99
VIP_QUARTERLY_PRICE_USD=999      # $9.99

VIP_TRIAL_DAYS=3

# ── RATE LIMITING ──────────────────────────────────────────────────────────
RATE_LIMIT_MESSAGES=30     # per minute
RATE_LIMIT_MATCHES=20      # per hour

# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANT NOTES:
# 
# 1. NEVER commit this file to GitHub!
#    Add .env to your .gitignore file
#
# 2. Keep RAZORPAY_KEY_SECRET private!
#    Never share it or expose it in frontend code
#
# 3. Start with TEST MODE
#    Test thoroughly before switching to LIVE MODE
#
# 4. Test Cards (Test Mode only):
#    Success: 4242 4242 4242 4242
#    Decline: 4000 0000 0000 0002
#    UPI (India): success@razorpay
#
# 5. When going live:
#    - Complete full KYC in Razorpay
#    - Switch to Live API keys
#    - Change RAZORPAY_MODE to "live"
#    - Test with real small payment first
#    - Update webhook URL to production domain
#
# ═══════════════════════════════════════════════════════════════════════════
