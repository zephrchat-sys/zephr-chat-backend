# zephr.chat — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to Git

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
WEBAPP_URL=https://your-frontend.vercel.app
# WEBHOOK_URL=https://your-backend.railway.app    # Uncomment for production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zephr:yourpassword@localhost:5432/zephrdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-64-character-hex-string

# ── AI Moderation (optional but recommended) ──────────────────────────────────
# Get free key at: https://developers.google.com/codelabs/setup-perspective-api
# PERSPECTIVE_API_KEY=your_perspective_api_key
TOXICITY_THRESHOLD=0.75

# ── Dev mode ──────────────────────────────────────────────────────────────────
# Set BOT_TOKEN=dev to bypass Telegram auth during local development
# BOT_TOKEN=dev
